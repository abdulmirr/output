# Supabase — from Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Site URL — used for OAuth + password-reset redirect callbacks.
# Must be set in production (Vercel) to the deployed URL, e.g. https://output.yourdomain.com
# In local dev this defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: gate access to onboarding behind a flag. Set to "true" to require it.
# NEXT_PUBLIC_ONBOARDING_GATE=true
